# Local development credentials for the Binary MoIP controller.
#
# Copy this file to `.env` (which is gitignored) and fill in real values:
#     cp .env.example .env
#
# This .env is ONLY used for local dev/test outside Home Assistant (e.g.
# scripts/dev_discover.py and tests). When the integration is installed
# normally in HA, credentials come from the "Add Integration" UI and are
# stored encrypted in HA's own config store — NOT from this file.
#
# See docs/development.md for details.

# Controller address.
MOIP_HOST=10.4.1.50

# HTTPS port (optional; defaults to 443).
MOIP_PORT=443

# Login credentials (same account used in OvrC / the MoIP web UI).
MOIP_USERNAME=your-username-here
MOIP_PASSWORD=your-password-here

# Verify the controller's TLS certificate (optional; defaults to false,
# since MoIP controllers typically use a self-signed cert).
MOIP_VERIFY_SSL=false
